{
  "_comment": "BPM별 섹션별 권장 패널 수와 지속 시간. panel_planner.py가 참조하여 스토리보드 생성.",
  "_style_note": "웹툰 스틸컷 MV 기준. 이미지 1장에 Ken Burns 효과(느린 줌/패닝)를 적용하여 5~8초 표시. BPM은 패널 수(다양성)에만 영향, 지속 시간은 웹툰 편집 기준으로 고정.",

  "bpm_ranges": {
    "slow":      { "min": 0,   "max": 89,  "label": "Slow (0–89 BPM)" },
    "medium":    { "min": 90,  "max": 119, "label": "Medium (90–119 BPM)" },
    "fast":      { "min": 120, "max": 149, "label": "Fast (120–149 BPM)" },
    "very_fast": { "min": 150, "max": 999, "label": "Very Fast (150+ BPM)" }
  },

  "sections": {
